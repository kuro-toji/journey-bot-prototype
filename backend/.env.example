# Backend env (example). Copy to .env and fill in real values.
# .env is gitignored. NEVER commit your real .env.

# Database
PGHOST=/tmp/pgsock
PGPORT=5433
PGUSER=suman
PGDATABASE=blostem

# HTTP server
PORT=4000

# JWT
JWT_SECRET=local-dev-secret-change-in-prod

# Demo OTP (universal — every phone uses this)
UNIVERSAL_OTP=123456

# MiniMax LLM (for the 'Talk to assistant' bot chip)
# Get your key at https://platform.minimax.io -> API Keys
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_TIMEOUT_MS=30000

# LLM rate limit (per hour)
LLM_RATE_LIMIT_AUTHED=20
LLM_RATE_LIMIT_ANON=5

# LLM cost guard (max tokens per completion)
LLM_MAX_COMPLETION_TOKENS=800
LLM_TEMPERATURE=0.5
